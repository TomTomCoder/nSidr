enum DocSourceType {
  markdown
  pdf
  url
  agent
}

enum DocLinkType {
  internal
  external
}

model ImportedDoc {
  id         String        @id @default(cuid())
  spaceId    String
  space      Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  title      String
  sourceType DocSourceType
  sourceUrl  String?
  rawContent String        @db.Text
  wordCount  Int
  createdBy  String
  creator    User          @relation("DocCreator", fields: [createdBy], references: [id])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  isIndexed  Boolean       @default(false)
  indexProgress Int        @default(0)
  chunkCount Int           @default(0)
  folderId   String?
  order      Float         @default(0)
  folder     DocFolder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)
  chunks     DocChunk[]
  linksFrom  DocLink[]     @relation("FromDoc")
  linksTo    DocLink[]     @relation("ToDoc")
  memoryEntities MemoryEntity[] @relation("DocMemory")

  @@index([spaceId])
  @@index([createdBy])
  @@map("imported_doc")
}

model DocFolder {
  id             String        @id @default(cuid())
  spaceId        String        @map("spaceId")
  parentFolderId String?       @map("parentId")
  name           String
  order          Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  space          Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  parent         DocFolder?    @relation("FolderChildren", fields: [parentFolderId], references: [id], onDelete: Cascade)
  children       DocFolder[]   @relation("FolderChildren")
  docs           ImportedDoc[]

  @@map("doc_folder")
}

model DocChunk {
  id          String      @id @default(cuid())
  docId       String
  doc         ImportedDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  chunkIndex  Int
  content     String      @db.Text
  embedding   Unsupported("vector(1536)")?
  tokenCount  Int
  startOffset Int
  endOffset   Int

  @@index([docId])
  @@map("doc_chunk")
}

model DocLink {
  id        String      @id @default(cuid())
  fromDocId String
  fromDoc   ImportedDoc @relation("FromDoc", fields: [fromDocId], references: [id], onDelete: Cascade)
  toDocId   String?
  toDoc     ImportedDoc? @relation("ToDoc", fields: [toDocId], references: [id], onDelete: SetNull)
  toUrl     String?
  linkText  String
  linkType  DocLinkType
  label     String?
  createdBy String?
  createdAt DateTime    @default(now())

  @@unique([fromDocId, toDocId, label], name: "doc_link_from_to_label_uq", map: "doc_link_from_to_label_uq")
  @@index([fromDocId])
  @@index([toDocId])
  @@map("doc_link")
}

// Agent memory graph (Phase 1): entities + relations extracted from documents.
// The `embedding` column is created via raw SQL migration (Unsupported by Prisma),
// mirroring DocChunk. Reads/writes use $queryRaw/$executeRaw.
model MemoryEntity {
  id             String   @id @default(cuid())
  spaceId        String
  name           String
  type           String
  summary        String   @db.Text
  embedding      Unsupported("vector(1536)")?
  sourceDocId    String?
  sourceDoc      ImportedDoc? @relation("DocMemory", fields: [sourceDocId], references: [id], onDelete: Cascade)
  version        Int      @default(1)
  supersededById String?
  createdAt      DateTime @default(now())
  relationsFrom  MemoryRelation[] @relation("FromEntity")
  relationsTo    MemoryRelation[] @relation("ToEntity")

  @@index([spaceId, name])
  @@index([sourceDocId])
  @@map("memory_entity")
}

model MemoryRelation {
  id           String       @id @default(cuid())
  spaceId      String
  fromEntityId String
  fromEntity   MemoryEntity @relation("FromEntity", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntityId   String
  toEntity     MemoryEntity @relation("ToEntity", fields: [toEntityId], references: [id], onDelete: Cascade)
  label        String
  weight       Float        @default(1)
  validFrom    DateTime     @default(now())
  validTo      DateTime?
  sourceDocId  String?
  createdAt    DateTime     @default(now())

  @@index([spaceId, fromEntityId])
  @@index([spaceId, toEntityId])
  @@map("memory_relation")
}

model Agent {
  id               String    @id @default(cuid())
  name             String
  description      String?
  baseId           String    @map("base_id")
  instructions     String?   @db.Text
  modelKey         String?   @map("model_key")
  isPublic         Boolean   @default(false) @map("is_public")
  isActive         Boolean   @default(true) @map("is_active")
  maxIterations    Int       @default(10) @map("max_iterations")
  // Plan-and-execute + reflexion (state-of-the-art agentic loop)
  planningEnabled   Boolean  @default(true) @map("planning_enabled")
  reflectionEnabled Boolean  @default(true) @map("reflection_enabled")
  maxReflections    Int      @default(2) @map("max_reflections")
  createdBy        String    @map("created_by")
  createdTime      DateTime  @default(now()) @map("created_time")
  lastModifiedTime DateTime? @updatedAt @map("last_modified_time")
  lastModifiedBy   String?   @map("last_modified_by")

  knowledgeSources Json?   @map("knowledge_sources")

  tools         AgentTool[]
  triggers      AgentTrigger[]
  memories      AgentMemory[]
  connections   AgentConnection[]
  conversations AgentConversation[]
  mcpServers    AgentMcpServer[]

  @@index([baseId])
  @@index([createdBy])
  @@map("agent")
}

