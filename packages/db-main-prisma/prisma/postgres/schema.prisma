  allowed     Boolean
  createdTime DateTime @default(now()) @map("created_time")
  createdBy   String   @map("created_by")

  @@unique([fieldId, principal, action])
  @@index([fieldId])
  @@map("field_permission")
}

model AuditLog {
  id           String   @id
  createdTime  DateTime @default(now()) @map("created_time")
  userId       String?  @map("user_id")
  spaceId      String?  @map("space_id")
  baseId       String?  @map("base_id")
  event        String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  ip           String?
  payload      Json?

  @@index([baseId, createdTime])
  @@index([spaceId, createdTime])
  @@index([userId, createdTime])
  @@map("audit_log")
}

model VerifiedDomain {
  id                String    @id
  spaceId           String    @map("space_id")
  domain            String
  verificationToken String    @map("verification_token")
  dnsRecordName     String    @map("dns_record_name")
  dnsRecordValue    String    @map("dns_record_value")
  verifiedAt        DateTime? @map("verified_at")
  createdBy         String    @map("created_by")
  createdTime       DateTime  @default(now()) @map("created_time")

  @@unique([spaceId, domain])
  @@index([spaceId])
  @@map("verified_domain")
}
