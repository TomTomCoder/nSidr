TIMEZONE=UTC

# Postgres
POSTGRES_HOST=teable-db
POSTGRES_PORT=5432
POSTGRES_DB=teable
POSTGRES_USER=teable
POSTGRES_PASSWORD=0000000000000000ffffffffffffffff

# Redis
REDIS_HOST=teable-cache
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=0000000000000000ffffffffffffffff

# App
PUBLIC_ORIGIN=http://192.168.1.43:3000
PRISMA_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
PUBLIC_DATABASE_PROXY=192.168.1.43:42345

BACKEND_CACHE_PROVIDER=redis
BACKEND_CACHE_REDIS_URI=redis://default:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# AI / LLM — configure at least one provider to enable the AI chat assistant
# Supported providers: openai | anthropic | openai_compatible
#AI_PROVIDER=openai
#OPENAI_API_KEY=sk-...
#ANTHROPIC_API_KEY=sk-ant-...
#AI_MODEL=gpt-4o
# For openai_compatible (e.g. Azure, local Ollama):
#AI_BASE_URL=https://your-endpoint/v1
#AI_API_KEY=your-key
