# Database
PRISMA_DATABASE_URL="postgresql://teable:teable@127.0.0.1:5432/teable"

# Perf: log any query slower than 300ms. The 2026-06-11 tour produced zero hits
# at this threshold, so any regression will stand out immediately in dev logs.
PRISMA_SLOW_QUERY_THRESHOLD_MS=300

# JWT
# Set these in your local .env.local or deployment secrets — do not commit real values
BACKEND_JWT_SECRET=local-dev-jwt-secret-change-in-prod
BACKEND_JWT_EXPIRES_IN="20d"

# Cache
BACKEND_CACHE_PROVIDER="redis"
BACKEND_CACHE_REDIS_URI="redis://127.0.0.1:6379"

# App
PUBLIC_ORIGIN="http://localhost:3000"
NEXTJS_PORT=3000
BACKEND_PORT=3002
INTEGRATION_SECRET_KEY=local-dev-integration-key-32chars

# Computed field update mode.
# NOTE: 'sync' makes the V2 container eagerly load the full dataset at boot, which
# exhausts the heap and crashes startup (FATAL: Reached heap limit) before the app
# can listen. Leave unset to use the default (background polling), which boots fine.
# V2_COMPUTED_UPDATE_MODE=sync

# --- Separated-mode overrides (copy these when running NestJS standalone) ---
# PORT=3002
# BACKEND_SKIP_NEXT_START=true
# Unset NEXTJS_PORT (not needed when Next.js runs in its own process)
# Note: port 3001 is reserved by Next.js Turbopack HMR (PORT+1), use 3002+
# -------------------------------------------------------------------------
